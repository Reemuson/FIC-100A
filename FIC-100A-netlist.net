(export (version "E")
  (design
    (source "/tmp/tmp-kibot-net_sch_print-lwgf6gwf/FIC-100A.kicad_sch")
    (date "Date")
    (tool "Eeschema 9.0.7+1")
    (textvar (name "ASSEMBLY_NOTES") "ASSEMBLY NOTES (UNLESS OTHERWISE SPECIFIED)\n\n1)	DO NOT POPULATE PARTS ARE MARKED WITH A RED CROSS.\n\n2)	DO NOT POPULATE PARTS ARE NOT PRESENT IN THE BOM.\n\n3)	IF CONFLICTING INFORMATION IS FOUND BETWEEN THE ASSEMBLY\n	FILE AND BOM, BOM SHOULD BE USED AS THE MAIN SOURCE.\n\n4)	CONFORMAL COATING IS NOT REQUIRED.\n\n5)	DOT IDENTIFIES PIN #1 LOCATION AND DEVICE ORIENTATION\n	WHEN VIEWED FROM THE TOP.")
    (textvar (name "BOARD_NAME") "FIC-100A")
    (textvar (name "COMPANY") "RYAN DYNAMICS")
    (textvar (name "DESIGNER") "R. HICKS")
    (textvar (name "FABRICATION_NOTES") "FABRICATION NOTES (UNLESS OTHERWISE SPECIFIED)\n\n1)	FABRICATE PER IPC-6012A CLASS 2.\n\n2)	OUTLINE DEFINED IN SEPARATE GERBER FILE WITH\n	\"Edge_Cuts.GBR\" SUFFIX.\n\n	DIMENSIONS OF CIRCUMSIZED RECTANGLE SHOWN ON THIS\n	DRAWING FOR REFERENCE ONLY.\n\n3)	SEE SEPARATE DRILL FILES WITH \".DRL\" SUFFIX \n	FOR HOLE LOCATIONS.\n\n	SELECTED HOLE LOCATIONS SHOWN ON THIS DRAWING \n	FOR REFERENCE ONLY.\n\n4)	SURFACE FINISH: ENIG\n\n5)	SOLDERMASK ON BOTH SIDES OF THE BOARD SHALL \n	BE LPI, COLOR GREEN.\n\n6)	SILK SCREEN LEGEND TO BE APPLIED PER LAYER \n	STACKUP USING YELLOW NON-CONDUCTIVE EPOXY INK.\n\n7)	ALL VIAS ARE TENTED ON BOTH SIDES UNLESS \n	SOLDERMASK OPENED IN GERBER.\n\n8)	VENDOR SHOULD FOLLOW ROHS COMPLIANT PROCESS \n	AND Pb FREE FOR MANUFACTURING\n\n9)	PCB MATERIAL REQUIREMENTS:\n\n	A.	FLAMMABILITY RATING MUST MEET OR EXCEED \n		UL94V-0 REQUIREMENTS.\n	B.	Tg 170 C OR EQUIVALENT.\n	C.	EQUIVALENT MATERIAL SHALL BE RoHS COMPLIANT, \n		HALOGEN FREE AND APPROVED BY RYAN DYNAMICS.\n\n10)	DESIGN GEOMETRY MINIMUM FEATURE SIZES:\n\n	BOARD SIZE				40.000 × 25.000 mm\n	BOARD THICKNESS		1.600 mm\n	TRACE WIDTH			0.200 mm\n	TRACE TO TRACE		0.200 mm\n	MIN. HOLE (PTH)			0.300 mm\n	MIN. HOLE (NPTH)		0.650 mm\n	ANNULAR RING			0.150 mm\n	COPPER TO HOLE		0.254 mm\n	COPPER TO EDGE		0.250 mm\n	HOLE TO HOLE			0.254 mm")
    (textvar (name "GIT_HASH_PCB") "62c012b")
    (textvar (name "GIT_HASH_SCH") "62c012b")
    (textvar (name "GIT_URL") "https://github.com/Reemuson/FIC-100A")
    (textvar (name "PROJECT_NAME") "USB IR ADPT")
    (textvar (name "RELEASE_BODY_0.1.0") "___________________________________\n\nStatus\n\n-   Checked pre-release.\n\n-   Schematic capture completed from the working breadboard prototype.\n\n-   Breadboard prototype tested with a Fluke 289 multimeter.\n\n-   PCB layout completed and ready to fabricate for further hardware testing.\n\n___________________________________\n\nAdded\n\n-   Initial KiCad schematic for the FIC-100A USB IR adapter.\n\n-   Initial 2-layer PCB layout.\n\n-   Initial generated manufacturing and documentation workflow.\n\n___________________________________\n\nNotes\n\n-   This release is intended for fabrication and test validation. The PCB has not yet been validated as an assembled production unit.")
    (textvar (name "RELEASE_BODY_1.0.0"))
    (textvar (name "RELEASE_BODY_1.0.1"))
    (textvar (name "RELEASE_BODY_1.0.2"))
    (textvar (name "RELEASE_BODY_1.1.0"))
